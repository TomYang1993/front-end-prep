DATABASE_URL="postgresql://postgres:postgres@localhost:5432/interview_platform"

# Auth (Supabase)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Billing provider: 'lemonsqueezy' or 'stripe'
BILLING_PROVIDER="lemonsqueezy"

# Lemon Squeezy (if BILLING_PROVIDER=lemonsqueezy)
LEMONSQUEEZY_API_KEY="YOUR_LS_API_KEY"
LEMONSQUEEZY_STORE_ID="YOUR_LS_STORE_ID"
LEMONSQUEEZY_WEBHOOK_SECRET="YOUR_LS_WEBHOOK_SECRET"

# Stripe (if BILLING_PROVIDER=stripe)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Shared billing config
PRO_PLAN_PRICE_ID="price_or_variant_id_here"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
